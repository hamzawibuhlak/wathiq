### 3. **TypeScript Standards**

```typescript
// ✅ ALWAYS define types
interface User {
  id: string;
  email: string;
  name: string;
  role: UserRole;
}

// ✅ Use enums for fixed values
enum UserRole {
  ADMIN = 'ADMIN',
  LAWYER = 'LAWYER',
  SECRETARY = 'SECRETARY',
}

// ✅ Use generic types
type ApiResponse<T> = {
  data: T;
  message?: string;
};

// ❌ Don't use 'any'
const data: any = response.data; // خطأ!

// ✅ Use 'unknown' if type is truly unknown
const data: unknown = response.data;
```

---

### 4. **Database Standards (Prisma)**

```prisma
// ✅ ALWAYS include tenantId in models
model Case {
  id        String   @id @default(uuid())
  // ... other fields
  tenantId  String   // مهم جداً!
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId]) // للأداء
  @@map("cases")
}

// ✅ Use proper relations
model Case {
  client   Client @relation(fields: [clientId], references: [id])
  clientId String
}

// ✅ Use enums in Prisma
enum CaseStatus {
  OPEN
  CLOSED
  SUSPENDED
}

// ✅ Add indexes for frequently queried fields
@@index([caseNumber])
@@index([status])
```

