### 7. **Code Quality Standards**

#### Comments:
```typescript
// ✅ Write comments in English for code
// Calculate total amount including tax
const total = subtotal + tax;

// ✅ Write user-facing text in Arabic
throw new NotFoundException('لم يتم العثور على القضية');

// ❌ Don't write obvious comments
// Get all cases
const cases = await this.casesService.findAll(); // واضح!
```

#### Functions:
```typescript
// ✅ Small, single-purpose functions
async function createCase(dto: CreateCaseDto, tenantId: string) {
  // validate
  await this.validateDto(dto);
  
  // generate case number
  const caseNumber = await this.generateCaseNumber(tenantId);
  
  // create
  return this.prisma.case.create({
    data: { ...dto, caseNumber, tenantId }
  });
}

// ❌ Don't create huge functions
async function processCase() {
  // 500 lines of code... خطأ!
}
```

#### DRY (Don't Repeat Yourself):
```typescript
// ✅ Extract common logic
async function findByIdOrFail(id: string, tenantId: string) {
  const entity = await this.prisma.case.findUnique({
    where: { id, tenantId }
  });
  
  if (!entity) {
    throw new NotFoundException();
  }
  
  return entity;
}

// ❌ Don't repeat this pattern everywhere
```

