### 2. **Frontend Standards**

#### Structure:
```
src/
├── components/
│   ├── ui/          (shadcn components - don't modify)
│   ├── layout/      (AppLayout, Sidebar, Header)
│   └── features/    (feature-specific components)
├── pages/           (one file per route)
├── api/             (API calls only)
├── hooks/           (custom hooks)
├── stores/          (Zustand stores)
├── lib/             (utilities)
└── types/           (TypeScript types)
```

#### Naming Conventions:
```typescript
// Components
- PascalCase: LoginPage.tsx, CaseCard.tsx
- Hooks: use*.ts (useAuth.ts, useCases.ts)
- Stores: *Store.ts (authStore.ts)
- API: *.ts (auth.ts, cases.ts)
- Types: *.types.ts
```

#### Component Pattern:
```typescript
// ✅ Preferred pattern
export function CaseCard({ case }: CaseCardProps) {
  // hooks at top
  const { mutate } = useDeleteCase();
  
  // handlers
  const handleDelete = () => {
    mutate(case.id);
  };
  
  // render
  return (
    <Card>
      {/* content */}
    </Card>
  );
}

// Define props interface
interface CaseCardProps {
  case: Case;
}
```

#### API Calls:
```typescript
// ✅ ALWAYS use axios instance with baseURL
import { api } from '@/lib/api';

export const casesApi = {
  getAll: (params?: CaseFilters) => 
    api.get<Case[]>('/cases', { params }),
  
  getById: (id: string) => 
    api.get<Case>(`/cases/${id}`),
  
  create: (data: CreateCaseDto) => 
    api.post<Case>('/cases', data),
};

// ✅ ALWAYS use TanStack Query
export function useCases(filters?: CaseFilters) {
  return useQuery({
    queryKey: ['cases', filters],
    queryFn: () => casesApi.getAll(filters),
  });
}
```

#### Styling:
```typescript
// ✅ Use Tailwind utility classes
<div className="flex items-center gap-4 rounded-lg bg-white p-4 shadow">

// ✅ Use shadcn/ui components
import { Button } from '@/components/ui/button';
<Button variant="outline">Click</Button>

// ❌ Don't use inline styles
<div style={{ padding: '16px' }}> // خطأ!

// ❌ Don't create custom CSS files
import './styles.css'; // خطأ!
```

#### RTL Support:
```typescript
// ✅ Use logical properties
className="ms-4"  // margin-start (not margin-left)
className="ps-4"  // padding-start (not padding-left)

// ✅ Text direction
<div dir="rtl" className="text-right">

// ✅ Flexbox
className="flex flex-row-reverse" // for RTL layout
```

