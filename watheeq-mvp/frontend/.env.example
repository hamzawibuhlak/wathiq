# ═══════════════════════════════════════════════════════════════════
# WATHEEQ FRONTEND - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# API Configuration
# ═══════════════════════════════════════════════════════════════════
# Development (local backend)
VITE_API_URL=http://localhost:3000/api

# Production (use relative path with nginx proxy)
# VITE_API_URL=/api

# ═══════════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════════
VITE_APP_NAME=Watheeq
VITE_APP_VERSION=1.0.0

# ═══════════════════════════════════════════════════════════════════
# Features (Optional)
# ═══════════════════════════════════════════════════════════════════
# VITE_ENABLE_ANALYTICS=false
# VITE_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════
# Build Configuration
# ═══════════════════════════════════════════════════════════════════
# VITE_BUILD_DATE= (auto-set during build)
