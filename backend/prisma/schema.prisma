// =====================================================
// Watheeq MVP - Prisma Schema
// Multi-tenant Law Office Management System
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ENUMS
// =====================================================

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  LAWYER
  SECRETARY
  ACCOUNTANT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  SUSPENDED
  CLOSED
  ARCHIVED
}

enum CaseType {
  CRIMINAL
  CIVIL
  COMMERCIAL
  LABOR
  FAMILY
  ADMINISTRATIVE
  REAL_ESTATE
  OTHER
}

enum HearingStatus {
  SCHEDULED
  COMPLETED
  POSTPONED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PENDING    // مستحق (تاريخ مستقبلي)
  SENT
  PAID
  OVERDUE    // متأخر
  CANCELLED
}

enum CasePriority {
  HIGH
  MEDIUM
  LOW
}

enum DocumentType {
  CONTRACT
  POWER_OF_ATTORNEY
  COURT_DOCUMENT
  COURT_ORDER
  PLEADING
  EVIDENCE
  CORRESPONDENCE
  INVOICE
  RECEIPT
  ID_DOCUMENT
  OTHER
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  NOT_APPLICABLE
}

// =====================================================
// TENANT (Law Office)
// =====================================================

model Tenant {
  id          String   @id @default(uuid())
  name        String   // اسم المكتب
  nameEn      String?  // English name (optional)
  email       String   @unique
  phone       String?
  address     String?
  city        String?
  licenseNumber String? // رقم الترخيص
  taxNumber   String?  // الرقم الضريبي
  commercialReg String? // السجل التجاري
  website     String?  // الموقع الإلكتروني
  logo        String?
  isActive    Boolean  @default(true)
  
  // SMTP Email Settings
  smtpHost        String?  // SMTP Server Host
  smtpPort        Int?     // SMTP Port (587 or 465)
  smtpUser        String?  // SMTP Username (email)
  smtpPass        String?  // SMTP Password (encrypted)
  smtpFrom        String?  // From Email Address
  smtpFromName    String?  // From Name
  smtpSecure      Boolean  @default(false) // true for SSL (465), false for TLS (587)
  smtpEnabled     Boolean  @default(false)
  
  // WhatsApp Settings
  whatsappAccessToken     String?  // Meta WhatsApp API Access Token
  whatsappPhoneNumberId   String?  // Phone Number ID
  whatsappBusinessId      String?  // Business Account ID
  whatsappWebhookToken    String?  // Webhook Verification Token
  whatsappEnabled         Boolean  @default(false)
  
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  // Relations
  users          User[]
  clients        Client[]
  cases          Case[]
  hearings       Hearing[]
  documents      Document[]
  documentTemplates DocumentTemplate[]
  invoices       Invoice[]
  emailTemplates EmailTemplate[]
  emailLogs      EmailLog[]
  smsLogs        SmsLog[]
  notifications  Notification[]
  rolePermissions RolePermission[]
  activityLogs   ActivityLog[]
  whatsappMessages WhatsAppMessage[]
  whatsappTemplates WhatsAppTemplate[]
  tasks          Task[]
  workflows      Workflow[]
  reports        Report[]
  reportExecutions ReportExecution[]
  userInvitations  UserInvitation[]
  calls            Call[]
  groupChats       GroupChat[]

  // Phase 23: Accounting & Finance
  accounts              Account[]
  journalEntries        JournalEntry[]
  accountsReceivable    AccountsReceivable[]
  arPayments            ARPayment[]
  accountsPayable       AccountsPayable[]
  apPayments            APPayment[]
  vendors               Vendor[]
  expenses              Expense[]
  expenseCategories     ExpenseCategory[]
  bankAccounts          BankAccount[]
  bankTransactions      BankTransaction[]
  bankReconciliations   BankReconciliation[]
  costCenters           CostCenter[]
  budgets               Budget[]
  fiscalYears           FiscalYear[]

  // Phase 24: HR Management
  employees             Employee[]
  departments           Department[]
  positions             Position[]
  employeeDocuments     EmployeeDocument[]
  attendanceRecords     Attendance[]
  attendanceSettings    AttendanceSettings?
  leaveTypes            LeaveType[]
  leaveRequests         LeaveRequest[]
  leaveBalances         LeaveBalance[]
  payrolls              Payroll[]
  payrollSettings       PayrollSettings?

  // Phase 25: Super Admin
  subscription          Subscription?

  // Phase 26: Internal Chat
  chatConversations     ChatConversation[]
  chatMessages          ChatMessage[]

  // Phase 27: Owner Panel
  companyProfile        CompanyProfile?
  tenantIntegrations    TenantIntegration[]

  // Phase 28: Legal Document Editor
  legalDocuments        LegalDocument[]
  legalDocTemplates     LegalDocTemplate[]

  // Phase 29: Marketing Module
  leads                 Lead[]
  leadActivities        LeadActivity[]       @relation("TenantLeadActivities")
  callScripts           CallScript[]
  callLogs              CallLog[]            @relation("TenantCallLogs")
  affiliates            Affiliate[]
  affiliateCommissions  AffiliateCommission[] @relation("TenantAffCommissions")
  campaigns             Campaign[]
  campaignContents      CampaignContent[]    @relation("TenantCampaignContents")
  campaignMetrics       CampaignMetric[]     @relation("TenantCampaignMetrics")
  adsConnections        AdsConnection[]
  adsMetrics            AdsMetric[]          @relation("TenantAdsMetrics")
  messageCampaigns      MessageCampaign[]
  messageRecipients     MessageRecipient[]   @relation("TenantMsgRecipients")
  contentCalendar       ContentCalendarItem[]

  // Phase 30: Legal Library
  legalBookmarks        LegalBookmark[]
  bookmarkFolders       BookmarkFolder[]
  caseLegalReferences   CaseLegalReference[]
  legalSearchLogs       LegalSearchLog[]

  @@map("tenants")
}

// =====================================================
// USER
// =====================================================

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String   // الاسم الكامل
  phone       String?
  role        UserRole @default(LAWYER)
  avatar      String?
  title       String?  // المسمى الوظيفي
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  lastLoginAt DateTime?
  lastLoginIp String?
  
  // Two-Factor Authentication
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-tenancy (optional for SUPER_ADMIN)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Created by (self-relation for tracking who created this user)
  createdById String?
  createdBy   User?    @relation("CreatedUsers", fields: [createdById], references: [id])
  createdUsers User[]  @relation("CreatedUsers")

  // Relations
  assignedCases Case[]    @relation("AssignedLawyer")
  createdCases  Case[]    @relation("CaseCreator")
  assignedHearings Hearing[] @relation("HearingLawyer")
  createdHearings  Hearing[] @relation("HearingCreator")
  documents     Document[]
  createdInvoices Invoice[]
  visibleClients Client[] @relation("ClientVisibility") // العملاء المرئيين لهذا المستخدم
  notifications Notification[]
  activityLogs  ActivityLog[]
  assignedTasks Task[]    @relation("AssignedTasks")
  createdTasks  Task[]    @relation("CreatedTasks")
  taskComments  TaskComment[]
  createdReports    Report[]          @relation("ReportCreator")
  executedReports   ReportExecution[] @relation("ReportExecutor")
  sentMessages      Message[]         @relation("SentMessages")
  receivedMessages  Message[]         @relation("ReceivedMessages")
  
  // Session & Invitation relations
  sessions           UserSession[]
  sentInvitations    UserInvitation[] @relation("InviterUser")
  acceptedInvitation UserInvitation?  @relation("AcceptedUser")
  
  // Communication Hub relations
  calls              Call[]
  createdGroups      GroupChat[]      @relation("GroupCreator")
  groupMemberships   GroupMember[]
  groupMessages      GroupMessage[]   @relation("GroupMessageSender")

  // Accounting relations
  createdJournalEntries  JournalEntry[] @relation("JournalEntryCreator")
  postedJournalEntries   JournalEntry[] @relation("JournalEntryPoster")
  approvedJournalEntries JournalEntry[] @relation("JournalEntryApprover")
  submittedExpenses      Expense[]      @relation("ExpenseSubmitter")
  approvedExpenses       Expense[]      @relation("ExpenseApprover")
  bankReconciliations    BankReconciliation[]

  // HR relations
  employee               Employee?      @relation("UserEmployee")
  reviewedLeaveRequests  LeaveRequest[] @relation("LeaveReviewer")
  processedPayrolls      Payroll[]      @relation("PayrollProcessor")

  // Phase 26: Internal Chat
  createdConversations   ChatConversation[]    @relation("ConversationCreator")
  chatMemberships        ChatConversationMember[]
  chatMessagesSent       ChatMessage[]         @relation("ChatMessageSender")
  chatReactions          ChatMessageReaction[]
  chatReceipts           ChatMessageReceipt[]

  // Phase 28: Legal Document Editor
  legalDocuments         LegalDocument[]        @relation("LegalDocCreator")
  legalDocVersions       LegalDocumentVersion[] @relation("LegalDocVersionSaver")

  // Phase 29: Marketing Module
  assignedLeads          Lead[]                 @relation("LeadAssignee")
  leadActivitiesCreated  LeadActivity[]         @relation("LeadActivityCreator")
  callLogsMade           CallLog[]              @relation("CallLogCaller")
  contentCalendarItems   ContentCalendarItem[]  @relation("ContentCalendarAssignee")

  // Phase 30: Legal Library
  legalBookmarks         LegalBookmark[]
  bookmarkFolders        BookmarkFolder[]
  caseLegalReferences    CaseLegalReference[]
  legalSearchLogs        LegalSearchLog[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}


// =====================================================
// CLIENT
// =====================================================

model Client {
  id              String   @id @default(uuid())
  name            String   // اسم العميل
  email           String?
  phone           String
  nationalId      String?  // رقم الهوية
  companyName     String?  // اسم الشركة (للعملاء التجاريين)
  commercialReg   String?  // السجل التجاري
  address         String?
  city            String?
  notes           String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Multi-tenancy
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  cases       Case[]
  hearings    Hearing[]
  invoices    Invoice[]
  visibleToUsers User[] @relation("ClientVisibility") // المستخدمين الذين يمكنهم رؤية هذا العميل
  whatsappMessages WhatsAppMessage[]
  
  // Client portal access
  portalAccessEnabled Boolean  @default(false)
  portalPassword      String?  // Hashed password
  lastPortalLogin     DateTime?
  portalLoginToken    String?  @unique

  @@index([tenantId])
  @@index([phone])
  @@index([nationalId])
  accountsReceivable AccountsReceivable[]

  // Phase 28: Legal Document Editor
  legalDocuments     LegalDocument[] @relation("ClientLegalDocs")

  @@map("clients")
}

// =====================================================
// CASE (القضية)
// =====================================================

model Case {
  id              String      @id @default(uuid())
  caseNumber      String      // رقم القضية (auto-generated)
  title           String      // عنوان القضية
  description     String?     // وصف القضية
  caseType        CaseType    @default(OTHER)
  status          CaseStatus  @default(OPEN)
  courtName       String?     // اسم المحكمة
  courtCaseNumber String?     // رقم القضية في المحكمة
  filingDate      DateTime?   // تاريخ رفع الدعوى
  nextHearingDate DateTime?   // تاريخ الجلسة القادمة
  notes           String?
  priority        CasePriority @default(MEDIUM)  // أولوية القضية
  opposingParty   String?     // الخصم
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Multi-tenancy
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id])
  
  assignedToId    String?
  assignedTo      User?       @relation("AssignedLawyer", fields: [assignedToId], references: [id])
  
  createdById     String
  createdBy       User        @relation("CaseCreator", fields: [createdById], references: [id])

  hearings        Hearing[]
  documents       Document[]
  invoices        Invoice[]
  whatsappMessages WhatsAppMessage[]
  tasks           Task[]

  // Phase 28: Legal Document Editor
  legalDocuments  LegalDocument[] @relation("CaseLegalDocs")

  // Phase 30: Legal Library
  caseLegalReferences CaseLegalReference[]

  @@unique([tenantId, caseNumber])
  @@index([tenantId])
  @@index([status])
  @@index([clientId])
  @@index([assignedToId])
  @@map("cases")
}

// =====================================================
// HEARING (الجلسة)
// =====================================================

model Hearing {
  id             String   @id @default(uuid())
  
  // رقم الجلسة من المحكمة
  hearingNumber  String   @default("")
  
  caseId         String?
  case           Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  
  // المحامي المسؤول عن الجلسة
  assignedToId   String?
  assignedTo     User?    @relation("HearingLawyer", fields: [assignedToId], references: [id])
  
  // من أنشأ الجلسة
  createdById    String?
  createdBy      User?    @relation("HearingCreator", fields: [createdById], references: [id])
  
  hearingDate    DateTime
  courtName      String?
  courtroom      String?
  opponentName   String?   // اسم الخصم
  judgeName      String?   // اسم القاضي
  status         HearingStatus @default(SCHEDULED)
  notes          String?
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId])
  @@index([caseId])
  @@index([clientId])
  @@index([assignedToId])
  @@index([createdById])
  @@map("hearings")
}

// =====================================================
// DOCUMENT (المستند)
// =====================================================

model Document {
  id              String       @id @default(uuid())
  title           String       // عنوان المستند
  description     String?
  fileName        String       // اسم الملف الأصلي
  filePath        String       // مسار الملف في التخزين
  fileSize        Int          // حجم الملف بالبايت
  mimeType        String       // نوع الملف
  documentType    DocumentType @default(OTHER)
  tags            String[]     // Array of tags
  
  // Versioning
  version         Int          @default(1)
  isLatest        Boolean      @default(true)
  parentId        String?      // Reference to previous version
  parent          Document?    @relation("DocumentVersions", fields: [parentId], references: [id])
  versions        Document[]   @relation("DocumentVersions")
  
  // OCR
  ocrText         String?      @db.Text
  ocrStatus       String       @default("PENDING")
  ocrError        String?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Multi-tenancy
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  caseId          String?
  case            Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  
  uploadedById    String
  uploadedBy      User         @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([caseId])
  @@index([documentType])
  @@index([parentId])
  @@index([isLatest])
  @@map("documents")
}

// =====================================================
// DOCUMENT TEMPLATE (قوالب المستندات)
// =====================================================

model DocumentTemplate {
  id          String       @id @default(uuid())
  name        String
  description String?
  category    DocumentType
  filePath    String
  fileSize    Int
  mimeType    String
  isActive    Boolean      @default(true)
  
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([tenantId])
  @@index([category])
  @@map("document_templates")
}

// =====================================================
// INVOICE (الفاتورة)
// =====================================================

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        // رقم الفاتورة (auto-generated)
  description     String?       // وصف الفاتورة
  amount          Decimal       @db.Decimal(10, 2)  // المبلغ
  taxAmount       Decimal       @default(0) @db.Decimal(10, 2)  // الضريبة
  totalAmount     Decimal       @db.Decimal(10, 2)  // المبلغ الإجمالي
  status          InvoiceStatus @default(DRAFT)
  issueDate       DateTime      @default(now())  // تاريخ الإصدار
  dueDate         DateTime      // تاريخ الاستحقاق
  paidAt          DateTime?     // تاريخ الدفع
  paymentProof    String?       // مسار ملف إثبات الدفع
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Multi-tenancy
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  
  caseId          String?
  case            Case?         @relation(fields: [caseId], references: [id], onDelete: SetNull)
  
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
  
  items           InvoiceItem[] // بنود الفاتورة
  accountsReceivable AccountsReceivable?

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

// =====================================================
// INVOICE ITEM (بند الفاتورة)
// =====================================================

model InvoiceItem {
  id          String   @id @default(uuid())
  description String   // وصف البند
  quantity    Int      // الكمية
  unitPrice   Decimal  @db.Decimal(10, 2)  // سعر الوحدة
  total       Decimal  @db.Decimal(10, 2)  // الإجمالي
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relation
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
  @@map("invoice_items")
}

// =====================================================
// EMAIL TEMPLATE (قالب البريد الإلكتروني)
// =====================================================

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String   // e.g., "hearing_reminder", "invoice_sent"
  subject     String
  body        String   @db.Text
  variables   Json     // Available variables for template
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Multi-tenancy
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([name])
  @@map("email_templates")
}

// =====================================================
// EMAIL LOG (سجل البريد الإلكتروني)
// =====================================================

model EmailLog {
  id          String    @id @default(uuid())
  to          String
  subject     String
  body        String    @db.Text
  status      String    // SENT, FAILED, PENDING
  sentAt      DateTime?
  error       String?   @db.Text
  
  createdAt   DateTime  @default(now())
  
  // Multi-tenancy
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("email_logs")
}

// =====================================================
// SMS LOG (سجل الرسائل النصية)
// =====================================================

model SmsLog {
  id        String    @id @default(uuid())
  to        String
  message   String    @db.Text
  status    String    // SENT, FAILED, PENDING
  sentAt    DateTime?
  error     String?   @db.Text
  response  String?   @db.Text
  
  createdAt DateTime  @default(now())
  
  // Multi-tenancy
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("sms_logs")
}

// =====================================================
// NOTIFICATION (الإشعارات الداخلية)
// =====================================================

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String   @db.Text
  type      String   // INFO, WARNING, SUCCESS, ERROR
  link      String?  // Optional link to related resource
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
  
  // User relation
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Multi-tenancy
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([isRead])
  @@map("notifications")
}

// =====================================================
// NOTIFICATION SETTINGS (إعدادات الإشعارات)
// =====================================================

model NotificationSettings {
  id                  String   @id @default(uuid())
  emailEnabled        Boolean  @default(true)
  smsEnabled          Boolean  @default(false)
  hearingReminders    Boolean  @default(true)
  caseUpdates         Boolean  @default(true)
  invoiceReminders    Boolean  @default(true)
  dailyDigest         Boolean  @default(false)
  reminderHoursBefore Int      @default(24)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // User relation
  userId              String   @unique
  
  // Multi-tenancy
  tenantId            String

  @@index([tenantId])
  @@map("notification_settings")
}

// =====================================================
// PERMISSION (الصلاحيات)
// =====================================================

model Permission {
  id          String   @id @default(uuid())
  name        String   // e.g., "cases.create", "invoices.delete"
  description String?
  module      String   // e.g., "cases", "invoices", "clients"
  action      String   // e.g., "create", "read", "update", "delete"
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

// =====================================================
// ROLE PERMISSION (صلاحيات الأدوار)
// =====================================================

model RolePermission {
  id           String     @id @default(uuid())
  role         String     // OWNER, ADMIN, LAWYER, SECRETARY
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([role, permissionId, tenantId])
  @@index([tenantId])
  @@index([role])
  @@map("role_permissions")
}

// =====================================================
// ACTIVITY LOG (سجل النشاطات)
// =====================================================

model ActivityLog {
  id          String   @id @default(uuid())
  action      String   // CREATE, UPDATE, DELETE, VIEW
  entity      String   // Case, Invoice, Client, etc.
  entityId    String?
  description String   @db.Text
  ipAddress   String?
  userAgent   String?  @db.Text
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([entity])
  @@index([createdAt])
  @@map("activity_logs")
}

// =====================================================
// WHATSAPP MESSAGE (رسائل واتساب)
// =====================================================

model WhatsAppMessage {
  id          String   @id @default(uuid())
  messageId   String?  @unique // WhatsApp message ID
  from        String   // Phone number (with country code)
  to          String   // Phone number (with country code)
  body        String   @db.Text
  type        String   // text, image, document, audio, video, template
  mediaUrl    String?
  status      String   @default("SENT") // SENT, DELIVERED, READ, FAILED
  direction   String   // INBOUND, OUTBOUND
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  error       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([from])
  @@index([to])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

// =====================================================
// WHATSAPP TEMPLATE (قوالب واتساب)
// =====================================================

model WhatsAppTemplate {
  id          String   @id @default(uuid())
  name        String   // Template name (lowercase, underscore separated)
  language    String   @default("ar") // ar, en
  category    String   // MARKETING, UTILITY, AUTHENTICATION
  header      String?
  body        String   @db.Text
  footer      String?
  buttons     Json?    // Array of buttons
  variables   Json?    // Array of variable names
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  isActive    Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("whatsapp_templates")
}

// =====================================================
// TASK (المهام)
// =====================================================

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  
  // Relations
  caseId      String?
  case        Case?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  
  hearingId   String?
  hearing     Hearing?     @relation(fields: [hearingId], references: [id], onDelete: SetNull)
  
  assignedToId String
  assignedTo   User         @relation("AssignedTasks", fields: [assignedToId], references: [id])
  
  createdById  String
  createdBy    User         @relation("CreatedTasks", fields: [createdById], references: [id])
  
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Task metadata
  tags        String[]
  completedAt DateTime?
  
  // Subtasks
  parentId    String?
  parent      Task?        @relation("SubTasks", fields: [parentId], references: [id])
  subtasks    Task[]       @relation("SubTasks")
  
  // Comments
  comments    TaskComment[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([tenantId])
  @@index([assignedToId])
  @@index([caseId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model TaskComment {
  id          String   @id @default(uuid())
  content     String   @db.Text
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([taskId])
  @@map("task_comments")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// =====================================================
// WORKFLOW (سير العمل الآلي)
// =====================================================

model Workflow {
  id          String          @id @default(uuid())
  name        String
  description String?
  isActive    Boolean         @default(true)
  
  // Trigger configuration
  triggerType WorkflowTrigger
  triggerConfig Json          // Flexible trigger configuration
  
  // Actions configuration
  actions     Json            // Array of actions to perform
  
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Execution tracking
  executions  WorkflowExecution[]
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  @@index([tenantId])
  @@index([triggerType])
  @@map("workflows")
}

model WorkflowExecution {
  id          String          @id @default(uuid())
  workflowId  String
  workflow    Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  status      ExecutionStatus @default(PENDING)
  triggerData Json
  result      Json?
  error       String?
  
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  
  @@index([workflowId])
  @@index([status])
  @@map("workflow_executions")
}

enum WorkflowTrigger {
  CASE_CREATED
  CASE_STATUS_CHANGED
  HEARING_SCHEDULED
  HEARING_REMINDER
  TASK_OVERDUE
  DOCUMENT_UPLOADED
  INVOICE_CREATED
  INVOICE_OVERDUE
  CLIENT_CREATED
  MANUAL
}

enum ExecutionStatus {
  PENDING
  RUNNING
  PROCESSING
  COMPLETED
  FAILED
}

// =====================================================
// REPORT TYPES
// =====================================================

enum ReportType {
  CASES_SUMMARY
  CASES_DETAILED
  HEARINGS_SCHEDULE
  FINANCIAL_SUMMARY
  CLIENT_ACTIVITY
  LAWYER_PERFORMANCE
  INVOICES_AGING
  CUSTOM
}

enum ExportFormat {
  PDF
  EXCEL
  CSV
  JSON
}

// =====================================================
// REPORT (التقارير)
// =====================================================

model Report {
  id          String      @id @default(uuid())
  name        String
  description String?
  reportType  ReportType
  
  // Configuration
  config      Json        // Filters, columns, grouping, etc.
  
  // Metadata
  createdById String
  creator     User        @relation("ReportCreator", fields: [createdById], references: [id])
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Executions
  executions  ReportExecution[]
  
  @@index([tenantId])
  @@index([reportType])
  @@map("reports")
}

// =====================================================
// MESSAGE (الرسائل الداخلية)
// =====================================================

model Message {
  id          String   @id @default(uuid())
  subject     String
  content     String   @db.Text
  isRead      Boolean  @default(false)
  
  // Sender
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  
  // Receiver
  receiverId  String
  receiver    User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  // Multi-tenancy
  tenantId    String
  
  // Soft delete
  deletedBySender   Boolean @default(false)
  deletedByReceiver Boolean @default(false)
  
  createdAt   DateTime @default(now())
  
  @@index([senderId])
  @@index([receiverId])
  @@index([tenantId])
  @@index([isRead])
  @@map("messages")
}

// =====================================================
// REPORT EXECUTION (تنفيذ التقارير)
// =====================================================

model ReportExecution {
  id          String          @id @default(uuid())
  reportId    String
  report      Report          @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  // Execution details
  status      ExecutionStatus @default(PENDING)
  format      ExportFormat
  filePath    String?
  fileSize    Int?
  
  // Metadata
  executedById String
  executor     User           @relation("ReportExecutor", fields: [executedById], references: [id])
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Error handling
  error       String?
  
  // Timestamps
  startedAt   DateTime        @default(now())
  completedAt DateTime?
  
  @@index([tenantId])
  @@index([reportId])
  @@index([status])
  @@map("report_executions")
}

// =====================================================
// USER INVITATION (دعوات المستخدمين)
// =====================================================

model UserInvitation {
  id             String           @id @default(uuid())
  email          String
  role           UserRole         @default(LAWYER)
  status         InvitationStatus @default(PENDING)
  
  // Inviter
  inviterId      String
  inviter        User             @relation("InviterUser", fields: [inviterId], references: [id])
  
  // Accepted user (filled when invitation is accepted)
  acceptedUserId String?          @unique
  acceptedUser   User?            @relation("AcceptedUser", fields: [acceptedUserId], references: [id])
  
  // Token for accepting invitation
  token          String           @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  
  // Multi-tenancy
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  @@index([tenantId])
  @@index([email])
  @@index([token])
  @@map("user_invitations")
}

// =====================================================
// USER SESSION (جلسات المستخدمين)
// =====================================================

model UserSession {
  id           String   @id @default(uuid())
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  deviceInfo   String?  // Device name/type
  location     String?  // Approximate location from IP
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  lastActivity DateTime @default(now())
  
  createdAt    DateTime @default(now())
  
  @@index([userId])
  @@index([token])
  @@index([isActive])
  @@map("user_sessions")
}

// =====================================================
// CALL CENTER (مركز الاتصالات)
// =====================================================

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  BUSY
  NO_ANSWER
  CANCELED
  FAILED
  ANSWERED
  VOICEMAIL
}

model Call {
  id              String        @id @default(uuid())
  twilioCallSid   String?       @unique
  direction       CallDirection
  from            String
  to              String
  status          CallStatus    @default(QUEUED)
  duration        Int?          // in seconds
  notes           String?       @db.Text
  
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  recording       CallRecording?
  
  createdAt       DateTime      @default(now())
  endedAt         DateTime?
  
  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("calls")
}

model CallRecording {
  id                  String   @id @default(uuid())
  callId              String   @unique
  call                Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  twilioRecordingSid  String?  @unique
  recordingUrl        String
  duration            Int      // in seconds
  createdAt           DateTime @default(now())
  
  @@map("call_recordings")
}

// =====================================================
// GROUP CHATS (الدردشات الجماعية)
// =====================================================

enum GroupRole {
  ADMIN
  MEMBER
}

model GroupChat {
  id          String         @id @default(uuid())
  name        String
  description String?
  avatar      String?
  
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdById String
  createdBy   User           @relation("GroupCreator", fields: [createdById], references: [id])
  
  members     GroupMember[]
  messages    GroupMessage[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([tenantId])
  @@map("group_chats")
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  group     GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime  @default(now())
  
  @@unique([groupId, userId])
  @@map("group_members")
}

model GroupMessage {
  id          String    @id @default(uuid())
  groupId     String
  group       GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("GroupMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  attachments String[]  @default([])
  metadata    Json?     // For voice messages, etc.
  createdAt   DateTime  @default(now())
  
  @@index([groupId, createdAt])
  @@map("group_messages")
}

// =====================================================
// PHASE 23: ACCOUNTING & FINANCE
// =====================================================

// ---- ENUMS ----

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountCategory {
  CURRENT_ASSET
  FIXED_ASSET
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  CAPITAL
  RETAINED_EARNINGS
  DRAWINGS
  OPERATING_REVENUE
  NON_OPERATING_REVENUE
  OPERATING_EXPENSE
  NON_OPERATING_EXPENSE
}

enum JournalEntryType {
  MANUAL
  INVOICE
  PAYMENT
  RECEIPT
  ADJUSTMENT
  OPENING_BALANCE
  CLOSING
  DEPRECIATION
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REVERSED
}

enum ARStatus {
  OUTSTANDING
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum APStatus {
  AP_OUTSTANDING
  AP_PARTIAL
  AP_PAID
  AP_OVERDUE
}

enum ExpenseStatus {
  EXP_PENDING
  EXP_APPROVED
  EXP_REJECTED
  EXP_PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  DEBIT_CARD
}

enum ReconciliationStatus {
  RECON_PENDING
  RECONCILED
  DISCREPANCY
}

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum BudgetStatus {
  BUDGET_ACTIVE
  BUDGET_CLOSED
  BUDGET_EXCEEDED
}

// ---- CHART OF ACCOUNTS ----

model Account {
  id              String          @id @default(uuid())
  accountNumber   String
  nameEn          String
  nameAr          String
  accountType     AccountType
  category        AccountCategory
  parentAccountId String?
  level           Int             @default(1)
  isActive        Boolean         @default(true)
  description     String?
  tenantId        String

  parentAccount   Account?        @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts   Account[]       @relation("AccountHierarchy")

  journalEntryLines JournalEntryLine[]
  budgets           Budget[]
  costCenterAccounts CostCenterAccount[]
  bankAccounts      BankAccount[]
  expenseCategories ExpenseCategory[]

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accountNumber])
  @@index([tenantId, accountType])
  @@index([tenantId, category])
  @@index([tenantId, isActive])
  @@map("accounts")
}

// ---- JOURNAL ENTRIES ----

model JournalEntry {
  id              String              @id @default(uuid())
  entryNumber     String
  date            DateTime
  description     String
  reference       String?
  type            JournalEntryType
  status          JournalEntryStatus  @default(DRAFT)
  isPosted        Boolean             @default(false)
  postedAt        DateTime?
  postedBy        String?
  createdBy       String
  approvedBy      String?
  approvedAt      DateTime?
  notes           String?             @db.Text
  tenantId        String
  createdAt       DateTime            @default(now())

  lines           JournalEntryLine[]
  creator         User                @relation("JournalEntryCreator", fields: [createdBy], references: [id])
  poster          User?               @relation("JournalEntryPoster", fields: [postedBy], references: [id])
  approver        User?               @relation("JournalEntryApprover", fields: [approvedBy], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entryNumber])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([tenantId, isPosted])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String        @id @default(uuid())
  journalEntryId  String
  accountId       String
  description     String?
  debit           Decimal       @default(0) @db.Decimal(15, 2)
  credit          Decimal       @default(0) @db.Decimal(15, 2)
  costCenterId    String?

  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account         Account       @relation(fields: [accountId], references: [id])
  costCenter      CostCenter?   @relation(fields: [costCenterId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// ---- ACCOUNTS RECEIVABLE ----

model AccountsReceivable {
  id              String        @id @default(uuid())
  invoiceId       String        @unique
  clientId        String
  amount          Decimal       @db.Decimal(15, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(15, 2)
  balance         Decimal       @db.Decimal(15, 2)
  dueDate         DateTime
  status          ARStatus      @default(OUTSTANDING)
  agingDays       Int           @default(0)
  tenantId        String
  createdAt       DateTime      @default(now())

  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [clientId], references: [id])
  payments        ARPayment[]
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([clientId])
  @@map("accounts_receivable")
}

model ARPayment {
  id              String              @id @default(uuid())
  arId            String
  paymentNumber   String
  amount          Decimal             @db.Decimal(15, 2)
  paymentDate     DateTime
  paymentMethod   PaymentMethod
  reference       String?
  notes           String?
  tenantId        String
  createdAt       DateTime            @default(now())

  ar              AccountsReceivable  @relation(fields: [arId], references: [id], onDelete: Cascade)
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, paymentNumber])
  @@index([arId])
  @@map("ar_payments")
}

// ---- ACCOUNTS PAYABLE ----

model Vendor {
  id              String            @id @default(uuid())
  vendorNumber    String
  name            String
  email           String?
  phone           String?
  address         String?
  vatNumber       String?
  notes           String?           @db.Text
  isActive        Boolean           @default(true)
  tenantId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  bills           AccountsPayable[]
  expenses        Expense[]
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, vendorNumber])
  @@index([tenantId, isActive])
  @@map("vendors")
}

model AccountsPayable {
  id              String        @id @default(uuid())
  billNumber      String
  vendorId        String
  amount          Decimal       @db.Decimal(15, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(15, 2)
  balance         Decimal       @db.Decimal(15, 2)
  billDate        DateTime
  dueDate         DateTime
  description     String
  status          APStatus      @default(AP_OUTSTANDING)
  reference       String?
  tenantId        String
  createdAt       DateTime      @default(now())

  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  payments        APPayment[]
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, billNumber])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([vendorId])
  @@map("accounts_payable")
}

model APPayment {
  id              String          @id @default(uuid())
  apId            String
  paymentNumber   String
  amount          Decimal         @db.Decimal(15, 2)
  paymentDate     DateTime
  paymentMethod   PaymentMethod
  reference       String?
  notes           String?
  tenantId        String
  createdAt       DateTime        @default(now())

  ap              AccountsPayable @relation(fields: [apId], references: [id], onDelete: Cascade)
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, paymentNumber])
  @@index([apId])
  @@map("ap_payments")
}

// ---- EXPENSES ----

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String
  accountId   String
  description String?
  tenantId    String

  account     Account   @relation(fields: [accountId], references: [id])
  expenses    Expense[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@map("expense_categories")
}

model Expense {
  id                String          @id @default(uuid())
  expenseNumber     String
  date              DateTime
  amount            Decimal         @db.Decimal(15, 2)
  expenseCategoryId String
  description       String
  reference         String?
  paymentMethod     PaymentMethod
  vendorId          String?
  costCenterId      String?
  attachments       String[]        @default([])
  status            ExpenseStatus   @default(EXP_PENDING)
  submittedBy       String
  approvedBy        String?
  approvedAt        DateTime?
  notes             String?
  tenantId          String
  createdAt         DateTime        @default(now())

  expenseCategory   ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])
  vendor            Vendor?         @relation(fields: [vendorId], references: [id])
  costCenter        CostCenter?     @relation(fields: [costCenterId], references: [id])
  submitter         User            @relation("ExpenseSubmitter", fields: [submittedBy], references: [id])
  approver          User?           @relation("ExpenseApprover", fields: [approvedBy], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, expenseNumber])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@map("expenses")
}

// ---- BANK ----

model BankAccount {
  id              String              @id @default(uuid())
  accountName     String
  bankName        String
  accountNumber   String
  iban            String?
  swiftCode       String?
  currency        String              @default("SAR")
  balance         Decimal             @db.Decimal(15, 2)
  accountId       String
  isActive        Boolean             @default(true)
  tenantId        String
  createdAt       DateTime            @default(now())

  account         Account             @relation(fields: [accountId], references: [id])
  transactions    BankTransaction[]
  reconciliations BankReconciliation[]
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accountNumber])
  @@index([tenantId, isActive])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String        @id @default(uuid())
  bankAccountId   String
  date            DateTime
  description     String
  reference       String?
  debit           Decimal       @default(0) @db.Decimal(15, 2)
  credit          Decimal       @default(0) @db.Decimal(15, 2)
  balance         Decimal       @db.Decimal(15, 2)
  isReconciled    Boolean       @default(false)
  reconciledAt    DateTime?
  tenantId        String

  bankAccount     BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([bankAccountId, date])
  @@index([tenantId, isReconciled])
  @@map("bank_transactions")
}

model BankReconciliation {
  id                String               @id @default(uuid())
  bankAccountId     String
  statementDate     DateTime
  statementBalance  Decimal              @db.Decimal(15, 2)
  bookBalance       Decimal              @db.Decimal(15, 2)
  difference        Decimal              @db.Decimal(15, 2)
  status            ReconciliationStatus @default(RECON_PENDING)
  reconciledBy      String?
  reconciledAt      DateTime?
  notes             String?              @db.Text
  tenantId          String

  bankAccount       BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciler        User?                @relation(fields: [reconciledBy], references: [id])
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([bankAccountId, statementDate])
  @@map("bank_reconciliations")
}

// ---- COST CENTERS ----

model CostCenter {
  id          String              @id @default(uuid())
  code        String
  name        String
  description String?
  isActive    Boolean             @default(true)
  tenantId    String

  journalEntryLines JournalEntryLine[]
  accounts    CostCenterAccount[]
  expenses    Expense[]
  budgets     Budget[]
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("cost_centers")
}

model CostCenterAccount {
  id           String     @id @default(uuid())
  costCenterId String
  accountId    String

  costCenter   CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  account      Account    @relation(fields: [accountId], references: [id])

  @@unique([costCenterId, accountId])
  @@map("cost_center_accounts")
}

// ---- BUDGETS ----

model Budget {
  id           String       @id @default(uuid())
  name         String
  fiscalYear   Int
  accountId    String
  costCenterId String?
  amount       Decimal      @db.Decimal(15, 2)
  spent        Decimal      @default(0) @db.Decimal(15, 2)
  remaining    Decimal      @db.Decimal(15, 2)
  period       BudgetPeriod @default(ANNUAL)
  startDate    DateTime
  endDate      DateTime
  status       BudgetStatus @default(BUDGET_ACTIVE)
  tenantId     String

  account      Account      @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, fiscalYear])
  @@index([tenantId, status])
  @@map("budgets")
}

// ---- FISCAL YEAR ----

model FiscalYear {
  id        String   @id @default(uuid())
  year      Int
  startDate DateTime
  endDate   DateTime
  isClosed  Boolean  @default(false)
  closedAt  DateTime?
  tenantId  String

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year])
  @@map("fiscal_years")
}

// =====================================================
// PHASE 24: HR MANAGEMENT
// =====================================================

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum EmploymentStatus {
  ACTIVE
  PROBATION
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RESIGNED
}

enum EmployeeDocumentType {
  EMP_CONTRACT
  ID_COPY
  PASSPORT_COPY
  IQAMA_COPY
  EDUCATIONAL_CERTIFICATE
  EXPERIENCE_CERTIFICATE
  MEDICAL_REPORT
  BANK_LETTER
  EMP_OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE_ATT
  WEEKEND
  HOLIDAY
}

enum LeaveStatus {
  LEAVE_PENDING
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELED
}

enum PayrollStatus {
  PAYROLL_DRAFT
  PAYROLL_PROCESSED
  PAYROLL_APPROVED
  PAYROLL_PAID
}

// ---- HR MODELS ----

model Employee {
  id                 String            @id @default(uuid())
  employeeNumber     String
  userId             String?           @unique

  // Personal Information
  firstName          String
  lastName           String
  firstNameAr        String?
  lastNameAr         String?
  dateOfBirth        DateTime
  gender             Gender
  nationality        String
  nationalIdNumber   String
  passportNumber     String?
  maritalStatus      MaritalStatus

  // Contact Information
  email              String?
  phone              String
  emergencyContact   Json?
  currentAddress     String?           @db.Text
  permanentAddress   String?           @db.Text

  // Employment Information
  jobTitle           String
  jobTitleAr         String?
  departmentId       String
  hireDate           DateTime
  probationEndDate   DateTime?
  contractType       ContractType
  employmentStatus   EmploymentStatus  @default(ACTIVE)
  workLocation       String?
  directManagerId    String?

  // Iqama/Work Permit
  iqamaNumber        String?
  iqamaExpiry        DateTime?
  workPermitNumber   String?
  workPermitExpiry   DateTime?
  borderNumber       String?

  // Compensation
  basicSalary        Decimal           @db.Decimal(10, 2)
  housingAllowance   Decimal           @default(0) @db.Decimal(10, 2)
  transportAllowance Decimal           @default(0) @db.Decimal(10, 2)
  otherAllowances    Json?

  // Bank Information
  bankName           String?
  accountNumber      String?
  iban               String?

  // Documents
  photoUrl           String?
  cvUrl              String?
  contractUrl        String?

  // Dates
  terminationDate    DateTime?
  terminationReason  String?           @db.Text
  lastWorkingDay     DateTime?

  // Metadata
  isActive           Boolean           @default(true)
  notes              String?           @db.Text
  tenantId           String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  // Relations
  user               User?             @relation("UserEmployee", fields: [userId], references: [id])
  department         Department        @relation(fields: [departmentId], references: [id])
  directManager      Employee?         @relation("EmployeeHierarchy", fields: [directManagerId], references: [id])
  subordinates       Employee[]        @relation("EmployeeHierarchy")
  documents          EmployeeDocument[]
  attendanceRecords  Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  payrolls           Payroll[]
  managedDepartments Department[]      @relation("DepartmentManager")
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeNumber])
  @@index([tenantId, employmentStatus])
  @@index([tenantId, departmentId])
  @@index([departmentId])
  @@index([directManagerId])
  @@map("employees")
}

model Department {
  id          String     @id @default(uuid())
  name        String
  nameAr      String?
  code        String
  description String?    @db.Text
  managerId   String?
  isActive    Boolean    @default(true)
  tenantId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  manager     Employee?  @relation("DepartmentManager", fields: [managerId], references: [id])
  employees   Employee[]
  positions   Position[]
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("departments")
}

model Position {
  id             String     @id @default(uuid())
  title          String
  titleAr        String?
  departmentId   String
  description    String?    @db.Text
  requirements   String?    @db.Text
  minSalary      Decimal    @db.Decimal(10, 2)
  maxSalary      Decimal    @db.Decimal(10, 2)
  isActive       Boolean    @default(true)
  tenantId       String
  createdAt      DateTime   @default(now())

  department     Department @relation(fields: [departmentId], references: [id])
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, title])
  @@map("positions")
}

model EmployeeDocument {
  id           String               @id @default(uuid())
  employeeId   String
  documentType EmployeeDocumentType
  title        String
  fileUrl      String
  uploadedAt   DateTime             @default(now())
  expiryDate   DateTime?
  notes        String?
  tenantId     String

  employee     Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
}

// ---- ATTENDANCE ----

model Attendance {
  id           String           @id @default(uuid())
  employeeId   String
  date         DateTime
  checkIn      DateTime?
  checkOut     DateTime?
  workHours    Decimal?         @db.Decimal(5, 2)
  status       AttendanceStatus @default(PRESENT)
  notes        String?
  location     String?
  ipAddress    String?
  isLate       Boolean          @default(false)
  lateMinutes  Int              @default(0)
  tenantId     String

  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([tenantId, date])
  @@index([employeeId])
  @@map("attendance")
}

model AttendanceSettings {
  id                 String   @id @default(uuid())
  workStartTime      String   @default("09:00")
  workEndTime        String   @default("17:00")
  gracePeriodMinutes Int      @default(15)
  autoCheckOut       Boolean  @default(false)
  autoCheckOutTime   String?
  weekendDays        String[] @default(["Friday", "Saturday"])
  tenantId           String   @unique

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("attendance_settings")
}

// ---- LEAVE MANAGEMENT ----

model LeaveType {
  id               String         @id @default(uuid())
  name             String
  nameAr           String?
  code             String
  daysPerYear      Int
  requiresApproval Boolean        @default(true)
  isPaid           Boolean        @default(true)
  maxConsecutiveDays Int?
  description      String?        @db.Text
  isActive         Boolean        @default(true)
  tenantId         String

  leaveRequests    LeaveRequest[]
  leaveBalances    LeaveBalance[]
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@map("leave_types")
}

model LeaveRequest {
  id              String        @id @default(uuid())
  employeeId      String
  leaveTypeId     String
  startDate       DateTime
  endDate         DateTime
  totalDays       Int
  reason          String        @db.Text
  status          LeaveStatus   @default(LEAVE_PENDING)
  requestedAt     DateTime      @default(now())
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?       @db.Text
  attachmentUrl   String?
  tenantId        String

  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType       LeaveType     @relation(fields: [leaveTypeId], references: [id])
  reviewer        User?         @relation("LeaveReviewer", fields: [reviewedBy], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([tenantId, status])
  @@map("leave_requests")
}

model LeaveBalance {
  id          String    @id @default(uuid())
  employeeId  String
  leaveTypeId String
  year        Int
  allocated   Int
  used        Int       @default(0)
  remaining   Int
  tenantId    String

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

// ---- PAYROLL ----

model Payroll {
  id                 String        @id @default(uuid())
  employeeId         String
  payrollMonth       Int
  payrollYear        Int
  payPeriodStart     DateTime
  payPeriodEnd       DateTime

  // Earnings
  basicSalary        Decimal       @db.Decimal(10, 2)
  housingAllowance   Decimal       @default(0) @db.Decimal(10, 2)
  transportAllowance Decimal       @default(0) @db.Decimal(10, 2)
  otherAllowances    Decimal       @default(0) @db.Decimal(10, 2)
  overtimeHours      Decimal       @default(0) @db.Decimal(5, 2)
  overtimeAmount     Decimal       @default(0) @db.Decimal(10, 2)
  bonus              Decimal       @default(0) @db.Decimal(10, 2)
  grossSalary        Decimal       @db.Decimal(10, 2)

  // Deductions
  gosiEmployee       Decimal       @default(0) @db.Decimal(10, 2)
  absenceDeduction   Decimal       @default(0) @db.Decimal(10, 2)
  lateDeduction      Decimal       @default(0) @db.Decimal(10, 2)
  loans              Decimal       @default(0) @db.Decimal(10, 2)
  otherDeductions    Decimal       @default(0) @db.Decimal(10, 2)
  totalDeductions    Decimal       @db.Decimal(10, 2)

  // Net
  netSalary          Decimal       @db.Decimal(10, 2)

  // Employer Contributions
  gosiEmployer       Decimal       @default(0) @db.Decimal(10, 2)

  // Status
  status             PayrollStatus @default(PAYROLL_DRAFT)
  processedAt        DateTime?
  processedBy        String?
  paidAt             DateTime?

  // Payment
  paymentMethod      String?
  paymentReference   String?

  notes              String?       @db.Text
  tenantId           String
  createdAt          DateTime      @default(now())

  employee           Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  processor          User?         @relation("PayrollProcessor", fields: [processedBy], references: [id])
  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([employeeId, payrollMonth, payrollYear])
  @@index([tenantId, payrollYear, payrollMonth])
  @@index([tenantId, status])
  @@map("payroll")
}

model PayrollSettings {
  id                    String   @id @default(uuid())
  gosiEmployeeRate      Decimal  @default(10) @db.Decimal(5, 2)
  gosiEmployerRate      Decimal  @default(12) @db.Decimal(5, 2)
  gosiMaxSalary         Decimal  @default(45000) @db.Decimal(10, 2)
  overtimeEnabled       Boolean  @default(true)
  overtimeRate          Decimal  @default(1.5) @db.Decimal(3, 2)
  absenceDeductionRate  Decimal  @default(1) @db.Decimal(3, 2)
  lateDeductionMinutes  Int      @default(30)
  lateDeductionRate     Decimal  @default(0.5) @db.Decimal(3, 2)
  workingDaysPerMonth   Int      @default(26)
  workingHoursPerDay    Decimal  @default(8) @db.Decimal(3, 1)
  tenantId              String   @unique

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_settings")
}

// =====================================================
// PHASE 25: SUPER ADMIN MODELS
// =====================================================

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubInvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AnnouncementType {
  INFO
  WARNING
  MAINTENANCE
  NEW_FEATURE
}

model SubscriptionPlan {
  id                String         @id @default(uuid())
  name              String
  nameAr            String
  slug              String         @unique
  description       String?        @db.Text
  descriptionAr     String?        @db.Text
  monthlyPrice      Decimal        @db.Decimal(10, 2)
  annualPrice       Decimal        @db.Decimal(10, 2)
  currency          String         @default("SAR")
  maxUsers          Int
  maxCases          Int
  maxStorageGB      Int
  maxClients        Int
  features          Json
  isActive          Boolean        @default(true)
  isPopular         Boolean        @default(false)
  subscriptions     Subscription[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("subscription_plans")
}

model Subscription {
  id                String             @id @default(uuid())
  tenantId          String             @unique
  planId            String
  status            SubscriptionStatus @default(TRIAL)
  billingCycle      BillingCycle       @default(MONTHLY)
  trialStartDate    DateTime?
  trialEndDate      DateTime?
  startDate         DateTime
  endDate           DateTime?
  renewalDate       DateTime?
  amount            Decimal            @db.Decimal(10, 2)
  currency          String             @default("SAR")
  paymentMethod     String?
  lastPaymentDate   DateTime?
  lastPaymentAmount Decimal?           @db.Decimal(10, 2)
  cancelledAt       DateTime?
  cancellationReason String?           @db.Text
  notes             String?            @db.Text
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])
  invoices          SubscriptionInvoice[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([status])
  @@index([renewalDate])
  @@map("subscriptions")
}

model SubscriptionInvoice {
  id              String          @id @default(uuid())
  subscriptionId  String
  invoiceNumber   String          @unique
  amount          Decimal         @db.Decimal(10, 2)
  vatAmount       Decimal         @db.Decimal(10, 2)
  totalAmount     Decimal         @db.Decimal(10, 2)
  status          SubInvoiceStatus @default(PENDING)
  dueDate         DateTime
  paidAt          DateTime?
  pdfUrl          String?
  subscription    Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())

  @@map("subscription_invoices")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string")
  description String?
  isPublic    Boolean  @default(false)
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model FeatureFlag {
  id           String   @id @default(uuid())
  key          String   @unique
  name         String
  description  String?
  isEnabled    Boolean  @default(false)
  enabledFor   String[]
  updatedBy    String?
  updatedAt    DateTime @updatedAt

  @@map("feature_flags")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  actorRole   String?
  tenantId    String?
  action      String
  resource    String
  resourceId  String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Announcement {
  id          String             @id @default(uuid())
  title       String
  titleAr     String?
  content     String             @db.Text
  contentAr   String?            @db.Text
  type        AnnouncementType   @default(INFO)
  targetPlans String[]
  isActive    Boolean            @default(true)
  startDate   DateTime
  endDate     DateTime?
  createdBy   String
  createdAt   DateTime           @default(now())

  @@map("announcements")
}

// =====================================================
// PHASE 26: INTERNAL CHAT SYSTEM
// =====================================================

enum ChatConversationType {
  DIRECT
  GROUP
}

enum ChatMemberRole {
  ADMIN
  MEMBER
}

enum ChatMessageType {
  TEXT
  FILE
  IMAGE
  VOICE
  SYSTEM
}

model ChatConversation {
  id           String               @id @default(uuid())
  type         ChatConversationType @default(DIRECT)
  name         String?
  description  String?
  avatarUrl    String?
  createdBy    String
  isActive     Boolean              @default(true)
  tenantId     String

  members      ChatConversationMember[]
  messages     ChatMessage[]
  creator      User                 @relation("ConversationCreator", fields: [createdBy], references: [id])
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@map("chat_conversations")
}

model ChatConversationMember {
  id             String           @id @default(uuid())
  conversationId String
  userId         String
  role           ChatMemberRole   @default(MEMBER)
  joinedAt       DateTime         @default(now())
  lastReadAt     DateTime?
  isMuted        Boolean          @default(false)
  isAdmin        Boolean          @default(false)
  leftAt         DateTime?

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("chat_conversation_members")
}

model ChatMessage {
  id             String          @id @default(uuid())
  conversationId String
  senderId       String
  content        String?         @db.Text
  type           ChatMessageType @default(TEXT)

  replyToId      String?

  fileUrl        String?
  fileName       String?
  fileSize       Int?
  fileMimeType   String?

  audioDuration  Int?

  isEdited       Boolean         @default(false)
  editedAt       DateTime?
  isDeleted      Boolean         @default(false)
  deletedAt      DateTime?

  tenantId       String

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation("ChatMessageSender", fields: [senderId], references: [id])
  replyTo        ChatMessage?     @relation("ChatMessageReplies", fields: [replyToId], references: [id])
  replies        ChatMessage[]    @relation("ChatMessageReplies")
  reactions      ChatMessageReaction[]
  receipts       ChatMessageReceipt[]
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([tenantId])
  @@map("chat_messages")
}

model ChatMessageReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([userId])
  @@map("chat_message_receipts")
}

model ChatMessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String

  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@map("chat_message_reactions")
}

// =====================================================
// PHASE 27: OWNER PANEL MODELS
// =====================================================

model CompanyProfile {
  id              String   @id @default(uuid())
  tenantId        String   @unique

  // Company data
  legalName       String
  legalNameAr     String?
  commercialRegNo String?
  vatNumber       String?
  licenseNumber   String?

  // Contact
  website         String?
  phone           String?
  email           String?
  address         String?  @db.Text
  city            String?
  country         String   @default("SA")

  // Branding
  logoUrl         String?
  primaryColor    String?  @default("#1a56db")

  // System settings
  timezone        String   @default("Asia/Riyadh")
  language        String   @default("ar")
  dateFormat      String   @default("DD/MM/YYYY")
  fiscalYearStart Int      @default(1)

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  updatedAt       DateTime @updatedAt

  @@map("company_profiles")
}

model TenantIntegration {
  id           String          @id @default(uuid())
  type         IntegrationType
  name         String
  isActive     Boolean         @default(false)
  config       Json
  lastTestedAt DateTime?
  lastTestOk   Boolean?
  tenantId     String

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([tenantId, type])
  @@map("tenant_integrations")
}

enum IntegrationType {
  EMAIL_SMTP
  EMAIL_SENDGRID
  WHATSAPP
  CALL_CENTER
  NAFATH
  ZATCA
  ABSHER
  GOOGLE_CALENDAR
  ZAPIER
}

// =====================================================
// Phase 28: LEGAL DOCUMENT EDITOR
// =====================================================

model LegalDocument {
  id              String               @id @default(uuid())
  title           String
  type            LegalDocumentType
  status          LegalDocumentStatus  @default(DRAFT)

  content         String               @db.Text
  contentText     String?              @db.Text

  caseId          String?
  clientId        String?

  version         Int                  @default(1)

  pdfUrl          String?
  wordUrl         String?
  lastExportedAt  DateTime?

  settings        Json?

  aiPromptUsed    String?              @db.Text
  aiGenerated     Boolean              @default(false)

  createdBy       String
  tenantId        String

  creator         User                 @relation("LegalDocCreator", fields: [createdBy], references: [id])
  case            Case?                @relation("CaseLegalDocs", fields: [caseId], references: [id])
  client          Client?              @relation("ClientLegalDocs", fields: [clientId], references: [id])
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions        LegalDocumentVersion[]

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, caseId])
  @@index([tenantId, status])
  @@map("legal_documents")
}

model LegalDocumentVersion {
  id          String   @id @default(uuid())
  documentId  String
  version     Int
  content     String   @db.Text
  savedBy     String
  changeNote  String?

  document    LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User          @relation("LegalDocVersionSaver", fields: [savedBy], references: [id])

  createdAt   DateTime @default(now())

  @@index([documentId])
  @@map("legal_document_versions")
}

model LegalDocTemplate {
  id          String            @id @default(uuid())
  name        String
  nameAr      String
  type        LegalDocumentType
  description String?
  content     String            @db.Text
  variables   Json
  isSystem    Boolean           @default(false)
  isActive    Boolean           @default(true)
  usageCount  Int               @default(0)

  tenantId    String?

  tenant      Tenant?           @relation(fields: [tenantId], references: [id])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([type])
  @@index([tenantId])
  @@map("legal_doc_templates")
}

enum LegalDocumentType {
  DEFENSE_MEMO
  REPLY
  CONTRACT
  POWER_OF_ATTORNEY
  APPEAL
  COMPLAINT
  LEGAL_OPINION
  SETTLEMENT
  LETTER
  OTHER
}

enum LegalDocumentStatus {
  DRAFT
  REVIEW
  FINAL
  SENT
  ARCHIVED
}

// =====================================================
// Phase 29: MARKETING MODULE
// =====================================================

model Lead {
  id            String      @id @default(uuid())
  name          String
  phone         String?
  email         String?
  source        LeadSource
  status        LeadStatus  @default(NEW)
  stage         LeadStage   @default(AWARENESS)
  score         Int         @default(0)
  notes         String?     @db.Text
  lostReason    String?

  assignedTo    String?
  caseId        String?
  campaignId    String?
  affiliateId   String?

  lastContactAt DateTime?
  nextFollowUp  DateTime?
  callAttempts  Int         @default(0)

  tenantId      String
  createdBy     String

  assignee      User?       @relation("LeadAssignee", fields: [assignedTo], references: [id])
  campaign      Campaign?   @relation(fields: [campaignId], references: [id])
  affiliate     Affiliate?  @relation(fields: [affiliateId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activities    LeadActivity[]
  callLogs      CallLog[]
  commissions   AffiliateCommission[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, source])
  @@index([assignedTo])
  @@map("leads")
}

model LeadActivity {
  id        String           @id @default(uuid())
  leadId    String
  type      LeadActivityType
  notes     String?          @db.Text
  duration  Int?
  outcome   String?
  createdBy String
  tenantId  String

  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User             @relation("LeadActivityCreator", fields: [createdBy], references: [id])
  tenant    Tenant           @relation("TenantLeadActivities", fields: [tenantId], references: [id])

  createdAt DateTime         @default(now())

  @@index([leadId])
  @@map("lead_activities")
}

model CallScript {
  id          String   @id @default(uuid())
  name        String
  content     String   @db.Text
  targetType  String
  isActive    Boolean  @default(true)
  tenantId    String

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  callLogs    CallLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("call_scripts")
}

model CallLog {
  id           String        @id @default(uuid())
  leadId       String?
  clientId     String?
  callerUserId String
  phone        String
  direction    CallDirection @default(OUTBOUND)
  status       CallStatus
  duration     Int?
  notes        String?       @db.Text
  recordingUrl String?
  scriptId     String?
  tenantId     String

  lead         Lead?         @relation(fields: [leadId], references: [id])
  callerUser   User          @relation("CallLogCaller", fields: [callerUserId], references: [id])
  script       CallScript?   @relation(fields: [scriptId], references: [id])
  tenant       Tenant        @relation("TenantCallLogs", fields: [tenantId], references: [id])

  createdAt    DateTime      @default(now())

  @@index([tenantId])
  @@index([leadId])
  @@index([callerUserId])
  @@map("call_logs")
}

model Affiliate {
  id              String          @id @default(uuid())
  name            String
  phone           String?
  email           String?
  referralCode    String          @unique
  commissionType  CommissionType
  commissionValue Float
  status          AffiliateStatus @default(ACTIVE)
  bankIban        String?
  bankName        String?
  totalEarned     Float           @default(0)
  totalPaid       Float           @default(0)
  tenantId        String

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  leads           Lead[]
  commissions     AffiliateCommission[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId])
  @@index([referralCode])
  @@map("affiliates")
}

model AffiliateCommission {
  id          String             @id @default(uuid())
  affiliateId String
  leadId      String
  amount      Float
  status      CommissionStatus   @default(PENDING)
  paidAt      DateTime?
  notes       String?
  tenantId    String

  affiliate   Affiliate          @relation(fields: [affiliateId], references: [id])
  lead        Lead               @relation(fields: [leadId], references: [id])
  tenant      Tenant             @relation("TenantAffCommissions", fields: [tenantId], references: [id])

  createdAt   DateTime           @default(now())

  @@index([affiliateId])
  @@map("affiliate_commissions")
}

model Campaign {
  id            String         @id @default(uuid())
  name          String
  type          CampaignType
  status        CampaignStatus @default(DRAFT)
  platform      String?
  budget        Float?
  spent         Float          @default(0)
  startDate     DateTime?
  endDate       DateTime?
  targetAudience String?       @db.Text
  goal          String?
  description   String?        @db.Text

  externalId    String?
  externalUrl   String?

  impressions   Int            @default(0)
  clicks        Int            @default(0)
  conversions   Int            @default(0)
  costPerClick  Float?
  costPerLead   Float?

  tenantId      String
  createdBy     String

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  leads         Lead[]
  contents      CampaignContent[]
  metrics       CampaignMetric[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("campaigns")
}

model CampaignContent {
  id          String   @id @default(uuid())
  campaignId  String
  type        String
  platform    String
  title       String?
  content     String   @db.Text
  mediaUrl    String?
  scheduledAt DateTime?
  publishedAt DateTime?
  status      String   @default("DRAFT")
  tenantId    String

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation("TenantCampaignContents", fields: [tenantId], references: [id])

  createdAt   DateTime @default(now())

  @@map("campaign_contents")
}

model CampaignMetric {
  id          String   @id @default(uuid())
  campaignId  String
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  conversions Int      @default(0)
  tenantId    String

  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation("TenantCampaignMetrics", fields: [tenantId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([campaignId, date])
  @@map("campaign_metrics")
}

model AdsConnection {
  id           String      @id @default(uuid())
  platform     AdsPlatform
  accountId    String
  accountName  String
  accessToken  String      @db.Text
  refreshToken String?     @db.Text
  isActive     Boolean     @default(true)
  lastSyncAt   DateTime?
  tenantId     String

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  metrics      AdsMetric[]

  createdAt    DateTime    @default(now())

  @@unique([tenantId, platform])
  @@map("ads_connections")
}

model AdsMetric {
  id           String      @id @default(uuid())
  connectionId String
  campaignId   String?
  campaignName String?
  date         DateTime    @db.Date
  platform     AdsPlatform
  impressions  Int         @default(0)
  clicks       Int         @default(0)
  spend        Float       @default(0)
  conversions  Int         @default(0)
  ctr          Float?
  cpc          Float?
  cpl          Float?
  roas         Float?
  tenantId     String

  connection   AdsConnection @relation(fields: [connectionId], references: [id])
  tenant       Tenant        @relation("TenantAdsMetrics", fields: [tenantId], references: [id])

  @@unique([connectionId, campaignId, date])
  @@index([tenantId, date])
  @@map("ads_metrics")
}

model MessageCampaign {
  id            String              @id @default(uuid())
  name          String
  type          MessageCampaignType
  status        CampaignStatus      @default(DRAFT)
  subject       String?
  content       String              @db.Text
  scheduledAt   DateTime?
  sentAt        DateTime?

  totalSent     Int                 @default(0)
  totalDelivered Int                @default(0)
  totalOpened   Int                 @default(0)
  totalClicked  Int                 @default(0)
  totalReplied  Int                 @default(0)

  targetType    String
  targetIds     Json?

  tenantId      String
  createdBy     String

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  recipients    MessageRecipient[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("message_campaigns")
}

model MessageRecipient {
  id          String          @id @default(uuid())
  campaignId  String
  recipientId String
  type        String
  name        String
  contact     String
  status      String          @default("PENDING")
  sentAt      DateTime?
  openedAt    DateTime?
  tenantId    String

  campaign    MessageCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tenant      Tenant          @relation("TenantMsgRecipients", fields: [tenantId], references: [id])

  @@index([campaignId])
  @@map("message_recipients")
}

model ContentCalendarItem {
  id          String        @id @default(uuid())
  title       String
  platform    String
  type        String
  status      ContentStatus @default(IDEA)
  content     String?       @db.Text
  mediaUrl    String?
  scheduledAt DateTime
  publishedAt DateTime?
  hashtags    String[]
  notes       String?
  assignedTo  String?
  campaignId  String?
  tenantId    String

  assignee    User?         @relation("ContentCalendarAssignee", fields: [assignedTo], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId, scheduledAt])
  @@map("content_calendar")
}

