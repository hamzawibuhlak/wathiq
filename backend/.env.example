# ═══════════════════════════════════════════════════════════════════
# WATHEEQ BACKEND - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════════════
NODE_ENV=development
PORT=3000
APP_NAME=Watheeq

# ═══════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL)
# ═══════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://watheeq:watheeq_secret@localhost:5432/watheeq?schema=public

# For Docker Compose (use container name)
# DATABASE_URL=postgresql://watheeq:watheeq_secret@postgres:5432/watheeq?schema=public

# ═══════════════════════════════════════════════════════════════════
# AUTHENTICATION (JWT)
# ═══════════════════════════════════════════════════════════════════
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════════════
# FILE UPLOADS
# ═══════════════════════════════════════════════════════════════════
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ═══════════════════════════════════════════════════════════════════
# REDIS (Optional - for caching and sessions)
# ═══════════════════════════════════════════════════════════════════
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# For Docker Compose with password
# REDIS_URL=redis://:your-redis-password@redis:6379

# ═══════════════════════════════════════════════════════════════════
# EMAIL (Optional - for notifications)
# ═══════════════════════════════════════════════════════════════════
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# SMTP_FROM=noreply@watheeq.sa

# ═══════════════════════════════════════════════════════════════════
# MEILISEARCH (Optional - for full-text search)
# ═══════════════════════════════════════════════════════════════════
# MEILI_HOST=http://localhost:7700
# MEILI_MASTER_KEY=your-meilisearch-master-key

# ═══════════════════════════════════════════════════════════════════
# CORS
# ═══════════════════════════════════════════════════════════════════
CORS_ORIGIN=http://localhost:5173

# For production (comma-separated list)
# CORS_ORIGIN=https://watheeq.sa,https://www.watheeq.sa

# ═══════════════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════════════
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ═══════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════
LOG_LEVEL=debug
# LOG_LEVEL=info (for production)
