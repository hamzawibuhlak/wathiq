# APPLICATION
NODE_ENV=production
PORT=3000
APP_NAME=وسم الثقة

# DATABASE — update host/password before deploying
DATABASE_URL="postgresql://watheeq:CHANGE_ME_STRONG_PASSWORD@postgres:5432/watheeq_prod?schema=public"

# AUTHENTICATION — generate new secret: openssl rand -base64 64
JWT_SECRET="7KpqR9mN3sT8vWxYzA2bC4dE6fG8hJ0kL1mN3oP5qR7sT9uV2wX4yZ6aB8cD0eF2gH4iJ6kL8mN0oP2qR4sT6uV8wX0yZ2aB4cD6eF8gH0iJ2kL4mN6oP8qR0sT"
