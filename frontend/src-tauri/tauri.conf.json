{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "وسم الثقة",
  "version": "1.0.0",
  "identifier": "sa.bewathiq.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "وسم الثقة — نظام إدارة المكاتب القانونية",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Business",
    "copyright": "© 2026 وسم الثقة",
    "shortDescription": "نظام إدارة المكاتب القانونية",
    "longDescription": "وسم الثقة — نظام شامل لإدارة المكاتب القانونية والمحاماة",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
